# 环境变量配置模板
# 复制此文件为 .env 并填写真实值

# ========================================
# 讯飞星火 API（必填）
# 申请地址：https://xinghuo.xfyun.cn/sparkapi
# ========================================
SPARK_APP_ID=your_app_id_here
SPARK_API_KEY=your_api_key_here
SPARK_API_SECRET=your_api_secret_here
# 推荐使用 4.0Ultra 版本
SPARK_DOMAIN=4.0Ultra

# ========================================
# 数据库
# ========================================
# 开发环境（SQLite）
DATABASE_URL=sqlite:///./learnpath.db
# 生产环境（PostgreSQL，取消注释）
# DATABASE_URL=postgresql://user:password@localhost:5432/learnpath

# ========================================
# 向量数据库
# ========================================
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=learnpath_knowledge

# ========================================
# 安全
# ========================================
# 生产环境请替换为随机字符串
SECRET_KEY=change-me-in-production-use-random-string

# ========================================
# 前端
# ========================================
VITE_API_BASE_URL=http://localhost:8000
