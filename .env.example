# 学径 LearnPath 环境变量示例（复制为 .env）

# LLM：true=强制 Mock（演示无 Key）；false=按下方 Key 路由真实模型
LLM_MOCK=false

# 讯飞星火（OpenAI 兼容）— 有 Key 时：画像/辅导/对话等主任务
SPARK_API_KEY=
SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v1
SPARK_MODEL=generalv3.5

# 辅助云端 LLM（OpenAI 兼容，无需本地权重）
# 推荐：硅基流动 https://cloud.siliconflow.cn  或 DeepSeek https://api.deepseek.com/v1
# 无星火 Key 时，主任务也走此通道；有星火时仅用于推荐文案、质检等次要任务
AUX_LLM_API_KEY=
AUX_LLM_BASE_URL=https://api.siliconflow.cn/v1
AUX_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# DeepSeek 示例：
# AUX_LLM_BASE_URL=https://api.deepseek.com/v1
# AUX_LLM_MODEL=deepseek-chat

# 数据库与向量库
DATABASE_URL=sqlite:///./storage/learnpath.db
CHROMA_PERSIST_DIR=./storage/chroma
KNOWLEDGE_BASE_DIR=./data/knowledge_base/ml_intro

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://127.0.0.1:3000,http://127.0.0.1:3001

# JWT（生产环境务必修改 JWT_SECRET）
JWT_SECRET=learnpath-dev-secret-change-in-production
JWT_EXPIRE_HOURS=72
AUTO_PATH_AFTER_GENERATE=true

# 开发：start.ps1 在 DEV_RELOAD=true 时为 uvicorn 加 --reload
DEV_RELOAD=true

# 讯飞 TTS（可选；无配置时 /api/tts/speak 返回 mock，前端回退浏览器朗读）
SPARK_TTS_URL=

# 前端：留空则走 Next 开发代理（推荐）；生产部署时填完整 API 地址
# NEXT_PUBLIC_API_BASE=
